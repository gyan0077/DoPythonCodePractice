#🧠 SECTION 1 — Lists

1: Write a Python program to remove duplicate elements from a list without using built-in set().


Method 1: Using a loop

# Remove duplicates from a list without using set()

original_list = [1, 2, 2, 3, 4, 4, 5]
unique_list = []

for item in original_list:
    if item not in unique_list:
        unique_list.append(item)

print("Original List:", original_list)
print("List after removing duplicates:", unique_list)


Method 2: Using list comprehension

original_list = [1, 2, 2, 3, 4, 4, 5]
unique_list = []

[unique_list.append(x) for x in original_list if x not in unique_list]

print(unique_list)


Method 3: Simple way (fastest) ⚡

original_list = [1, 2, 2, 3, 4, 4, 5]

unique_list = list(set(original_list))

print("Original List:", original_list)
print("List after removing duplicates:", unique_list)


Method 4: Using set() while preserving order ⭐
 
original_list = [3, 1, 2, 1, 4, 2, 5]

seen = set()
unique_list = []

for item in original_list:
    if item not in seen:
        seen.add(item)
        unique_list.append(item)

print("List after removing duplicates:", unique_list)




2: Write a Python program to find the second largest number in a list.

Method 1: Using sorting

numbers = [10, 20, 4, 45, 99]
numbers.sort()
second_largest = numbers[-2]
print("Second largest number:", second_largest)

Method 2: Without sorting

numbers = [10, 20, 4, 45, 99]

largest = second_largest = float('-inf')
for num in numbers:
    if num > largest:
        second_largest = largest
        largest = num
    elif num > second_largest and num != largest:
        second_largest = num
print("Second largest number:", second_largest)


Method 3: Using set() (handles duplicates automatically) ✨

numbers = [10, 20, 4, 45, 99, 99]

unique_numbers = list(set(numbers))
unique_numbers.sort()

print("Second largest number:", unique_numbers[-2])


3: Write a Python program to count the occurrence of each element in a list.

Method 1: Using dictionary
# Count occurrence of each element in a list

numbers = [1, 2, 2, 3, 4, 4, 4, 5]
count_dict = {}

for num in numbers:
    if num in count_dict:
        count_dict[num] += 1
    else:
        count_dict[num] = 1
print("Element occurrences:", count_dict)

Method 2: Using collections.Counter

from collections import Counter
numbers = [1, 2, 2, 3, 4, 4, 4, 5]
count = Counter(numbers)
print(count)



4: Write a Python program to merge two lists into a single list without duplicates.

Method 1: Using set()

list1 = [1, 2, 3, 4]
list2 = [3, 4, 5, 6]

merged_list = list(set(list1 + list2))
print("Merged list without duplicates:", merged_list)

⚠️ Note: This method does not preserve order

Method 2: Preserve order

list1 = [1, 2, 3, 4]
list2 = [3, 4, 5, 6]

merged_list = []
seen = set()

for item in list1 + list2:
    if item not in seen:
        merged_list.append(item)
        seen.add(item)

print("Merged list without duplicates:", merged_list)


Method 3: Without using set()

list1 = [1, 2, 3, 4]
list2 = [3, 4, 5, 6]

merged_list = list1.copy()

for item in list2:
    if item not in merged_list:
        merged_list.append(item)

print("Merged list without duplicates:", merged_list)




5: Write a Python program to split a list into even numbers and odd numbers.

Method 1: Using a loop

numbers = [10, 15, 22, 33, 40, 55, 60]
even_numbers = []
odd_numbers = []

for num in numbers:
    if num % 2 == 0:
        even_numbers.append(num)
    else:
        odd_numbers.append(num)

print("Even numbers:", even_numbers)
print("Odd numbers:", odd_numbers)

Method 2: Using list comprehension

numbers = [10, 15, 22, 33, 40, 55, 60]

even_numbers = [num for num in numbers if num % 2 == 0]

odd_numbers = [num for num in numbers if num % 2 != 0]

print("Even numbers:", even_numbers)
print("Odd numbers:", odd_numbers)



6: Write a Python program to flatten a nested list.

nested_list = [1, 2, [3, 4], [5, 6]]
flat_list = []

for item in nested_list:
    if isinstance(item, list):
        for sub_item in item:
            flat_list.append(sub_item)
    else:
        flat_list.append(item)
print("Flattened list:", flat_list)

Method 2: Using list comprehension

nested_list = [1, 2, [3, 4], [5, 6]]

flat_list = 
[element for item in nested_list for element in (item if isinstance(item, list) else [item])]

print(flat_list)




